# Linux/Mac 서버에서 LF, Windows에서 CRLF 자동 처리
* text=auto

# Python, JS, CSS는 항상 LF (Ubuntu 서버 기준)
*.py text eol=lf
*.jsx text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.sh text eol=lf
Dockerfile text eol=lf
.env* text eol=lf

# 바이너리
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
