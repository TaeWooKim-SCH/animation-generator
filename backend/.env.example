# HuggingFace token (required to download SVD model)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# SVD model variant
# Options: stabilityai/stable-video-diffusion-img2vid
#          stabilityai/stable-video-diffusion-img2vid-xt  (recommended, 25 frames)
SVD_MODEL=stabilityai/stable-video-diffusion-img2vid-xt

# Local cache directory for models (optional)
HF_HOME=./hf_cache

# Device backend selection
# Options: cuda (NVIDIA GPU), mps (Apple Silicon), cpu (fallback)
# Leave empty for auto-detection (recommended)
# DEVICE=

# Server settings
HOST=0.0.0.0
PORT=8000

# Output directory for generated files
OUTPUT_DIR=./outputs

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
